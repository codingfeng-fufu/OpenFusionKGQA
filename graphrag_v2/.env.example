# GraphRAG v2 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# ========== OpenAI API 配置 ==========
# 默认聊天模型的 API 密钥
GRAPHRAG_API_KEY=your-openai-api-key-here

# 默认嵌入模型的 API 密钥（如果与聊天模型相同，可以不设置）
GRAPHRAG_EMBEDDING_API_KEY=your-openai-api-key-here

# ========== Azure OpenAI 配置（可选） ==========
# GRAPHRAG_AZURE_API_BASE=https://your-resource.openai.azure.com/
# GRAPHRAG_AZURE_API_VERSION=2024-02-15-preview
# GRAPHRAG_AZURE_DEPLOYMENT_NAME=gpt-4

# ========== 项目配置 ==========
# 项目根目录（可选，默认为当前目录）
# GRAPHRAG_ROOT_DIR=/path/to/your/project

# ========== 其他配置 ==========
# 代理服务器（可选）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

