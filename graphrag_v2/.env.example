# OpenFusionKGQA 环境变量配置示例
# 真实 LLM API key 推荐写入 ignored YAML 配置文件：
#   cp settings.llm.neo4j.example.yaml settings.local.real-llm.yaml
#   export KGQA_REAL_LLM_CONFIG=settings.local.real-llm.yaml

# ========== 真实 LLM smoke 配置 ==========
KGQA_REAL_LLM_SMOKE=0
# KGQA_REAL_LLM_CONFIG=settings.local.real-llm.yaml

# ========== 旧环境变量兼容 ==========
# 以下变量仍会被 redaction/security tooling 识别，保留是为了兼容旧配置。
# GRAPHRAG_API_KEY=your-legacy-chat-api-key
# GRAPHRAG_EMBEDDING_API_KEY=your-legacy-embedding-api-key

# ========== Azure OpenAI 配置（可选） ==========
# GRAPHRAG_AZURE_API_BASE=https://your-resource.openai.azure.com/
# GRAPHRAG_AZURE_API_VERSION=2024-02-15-preview
# GRAPHRAG_AZURE_DEPLOYMENT_NAME=gpt-4

# ========== 项目配置 ==========
# 项目根目录（可选，默认为当前目录）
# GRAPHRAG_ROOT_DIR=/path/to/your/project

# ========== 其他配置 ==========
# 代理服务器（可选）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
