# GraphRAG v2 配置文件模板
# 参考微软 GraphRAG 的配置设计

# ========== 基础配置 ==========
root_dir: "."  # 项目根目录

# ========== 语言模型配置 ==========
models:
  # 默认聊天模型（用于实体提取、社区报告等）
  default_chat_model:
    type: "chat"  # 模型类型: chat, embedding, openai_chat, azure_openai_chat 等
    model: "gpt-4o-mini"  # 模型名称
    model_provider: "openai"  # 模型提供商: openai, azure, anthropic 等
    auth_type: "api_key"  # 认证类型: api_key, azure_managed_identity
    api_key: "${GRAPHRAG_API_KEY}"  # API 密钥（从环境变量读取）
    # api_base: "https://api.openai.com/v1"  # API 基础 URL（可选）
    # api_version: "2024-02-15-preview"  # API 版本（Azure OpenAI 需要）
    # deployment_name: "gpt-4"  # 部署名称（Azure OpenAI 需要）
    max_tokens: 4000  # 最大生成 token 数
    temperature: 0.0  # 温度参数（0-1，越高越随机）
    top_p: 1.0  # Top-p 采样参数
    tokens_per_minute: 150000  # 每分钟 token 限制
    requests_per_minute: 10000  # 每分钟请求限制
    concurrent_requests: 25  # 并发请求数
    max_retries: 10  # 最大重试次数
    max_retry_wait: 10.0  # 最大重试等待时间（秒）
    request_timeout: 60.0  # 请求超时时间（秒）

  # 默认嵌入模型（用于文本向量化）
  default_embedding_model:
    type: "embedding"
    model: "text-embedding-3-small"
    model_provider: "openai"
    auth_type: "api_key"
    api_key: "${GRAPHRAG_EMBEDDING_API_KEY}"  # 可以使用不同的 API 密钥
    tokens_per_minute: 150000
    requests_per_minute: 10000
    concurrent_requests: 25
    max_retries: 10

# ========== 输入配置 ==========
input:
  file_type: "text"  # 输入文件类型: text, csv, json
  file_pattern: ".*\\.txt$"  # 文件匹配模式（正则表达式）
  base_dir: "input"  # 输入文件目录
  encoding: "utf-8"  # 文件编码
  storage:
    type: "file"  # 存储类型: file, blob, memory
    base_dir: "input"  # 存储基础目录

# ========== 输出配置 ==========
output:
  type: "file"  # 输出类型: file, blob, memory
  base_dir: "output"  # 输出目录
  # connection_string: ""  # Blob 存储连接字符串（可选）
  # container_name: ""  # Blob 容器名称（可选）

# ========== 缓存配置 ==========
cache:
  type: "file"  # 缓存类型: file, blob, memory, none
  base_dir: "cache"  # 缓存目录
  # connection_string: ""  # Blob 存储连接字符串（可选）
  # container_name: ""  # Blob 容器名称（可选）

# ========== 文本分块配置 ==========
chunks:
  size: 1200  # 分块大小（token 数量）
  overlap: 100  # 分块重叠大小（token 数量）
  group_by_columns: ["id"]  # 分组列名
  strategy: "tokens"  # 分块策略: tokens, sentence
  encoding_model: "cl100k_base"  # 编码模型（用于计算 token）

